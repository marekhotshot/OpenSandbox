+                "timeout": 180,
+                "fallback": "none",
+                "runner_overrides": {
+                    "enabled_for_profile": ["clouddev_runpod_runner"],
+                    "allowed_runners": ["code"],
+                },
+            }
+        }
+        base["runpod"].update(overrides)
+        return base
+
+    def _env(self, **kwargs) -> Dict[str, str]:
+        return dict(kwargs)
+
+    def test_disabled_block_returns_empty(self) -> None:
+        cfg = self._cfg(enabled=False)
+        env = self._env(
+            RUNPOD_API_KEY="secret",
+            RUNPOD_OPENAI_BASE_URL="https://api.runpod.ai/v2/x/openai/v1",
+        )
+        self.assertEqual(
+            self.resolve(cfg, "clouddev_runpod_runner", env=env), {}
+        )
+
+    def test_no_runtime_profile_returns_empty(self) -> None:
+        env = self._env(
+            RUNPOD_API_KEY="secret",
+            RUNPOD_OPENAI_BASE_URL="https://api.runpod.ai/v2/x/openai/v1",
+        )
+        self.assertEqual(self.resolve(self._cfg(), None, env=env), {})
+
+    def test_wrong_profile_returns_empty(self) -> None:
+        env = self._env(
+            RUNPOD_API_KEY="secret",
+            RUNPOD_OPENAI_BASE_URL="https://api.runpod.ai/v2/x/openai/v1",
+        )
+        self.assertEqual(self.resolve(self._cfg(), "local_qwen", env=env), {})
+
+    def test_missing_api_key_returns_empty(self) -> None:
+        env = self._env(
+            RUNPOD_OPENAI_BASE_URL="https://api.runpod.ai/v2/x/openai/v1"
+        )
+        self.assertEqual(
+            self.resolve(self._cfg(), "clouddev_runpod_runner", env=env), {}
+        )
+
+    def test_missing_base_url_returns_empty(self) -> None:
+        env = self._env(RUNPOD_API_KEY="secret")
+        self.assertEqual(
+            self.resolve(self._cfg(), "clouddev_runpod_runner", env=env), {}
+        )
+
+    def test_happy_path_yields_runpod_client_per_runner(self) -> None:
+        env = self._env(
+            RUNPOD_API_KEY="secret",
+            RUNPOD_OPENAI_BASE_URL="https://api.runpod.ai/v2/x/openai/v1",
