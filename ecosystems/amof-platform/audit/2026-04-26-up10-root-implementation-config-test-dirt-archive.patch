+from __future__ import annotations
+
+import sys
+import tempfile
+import time
+import unittest
+from pathlib import Path
+
+sys.path.insert(0, str(Path(__file__).parent.parent / "scripts"))
+
+from amof.orchestrator.agent import Agent  # noqa: E402
+from amof.orchestrator.events import EventLog  # noqa: E402
+from amof.orchestrator.llm.base import LLMResponse, ToolCallRequest, Usage  # noqa: E402
+from amof.orchestrator.session import Session  # noqa: E402
+from amof.orchestrator.telemetry import SessionTelemetry  # noqa: E402
+from amof.orchestrator.tools.base import Tool, ToolRegistry, ToolResult  # noqa: E402
+from amof.orchestrator.tools.shell import ShellTool  # noqa: E402
+
+
+class TestShellToolInterruptibility(unittest.TestCase):
+    def test_shell_tool_honors_stop_checker(self) -> None:
+        started_at = time.monotonic()
+        tool = ShellTool(
+            stop_checker=lambda: (time.monotonic() - started_at) >= 0.5
+        )
+
+        result = tool.execute(
+            "python3 -c \"import time; print('START', flush=True); "
+            "time.sleep(10); print('DONE', flush=True)\"",
+            timeout=30,
+        )
+
+        self.assertFalse(result.success)
+        self.assertTrue(result.cancelled)
+        self.assertIn("START", result.output)
+        self.assertNotIn("DONE", result.output)
+        self.assertIn("stop request", (result.error or "").lower())
+
+
+class _CancelTool(Tool):
+    name = "CancelTool"
+    description = "Synthetic cancellation tool for agent-loop tests."
+    parameters = {
+        "type": "object",
+        "properties": {},
+        "required": [],
+    }
+
+    def execute(self, **params):
+        return ToolResult(
+            success=False,
+            output="Exit code: 130\n\nCancelled during active tool work.",
+            error="Command cancelled due to stop request",
+            cancelled=True,
+        )
+
+
+class _SingleToolLLM:
+    def chat(self, system, messages, tools=None, max_tokens=8192, temperature=0.0):
+        return LLMResponse(
+            text=None,
+            tool_calls=[
+                ToolCallRequest(id="cancel-1", name="CancelTool", arguments={})
+            ],
+            usage=Usage(
+                model="local/test",
+                prompt_tokens=10,
+                completion_tokens=5,
+                latency_ms=1,
+                estimated_cost=0.0,
+            ),
+            stop_reason="tool_use",
+        )
+
+    def model_name(self) -> str:
+        return "local/test"
+
+    def context_window(self) -> int:
+        return 32000
+
+
+class TestAgentCancellationOnCancelledTool(unittest.TestCase):
+    def test_agent_sets_cancelled_stop_reason(self) -> None:
+        registry = ToolRegistry()
+        registry.register(_CancelTool())
+
+        events_dir = Path(tempfile.mkdtemp(prefix="amof-shell-cancel-events-"))
+        agent = Agent(
+            llm=_SingleToolLLM(),
+            tools=registry,
+            system_prompt="test",
+            session=Session(),
+            telemetry=SessionTelemetry(),
+            events=EventLog(session_id="cancelled-tool", runs_dir=events_dir),
+            verbose=False,
+            max_iterations=3,
+        )
+
+        result = agent.run("trigger cancellation")
+
+        self.assertEqual(agent.stop_reason, "cancelled")
+        self.assertIn("Stop requested", result)
+
+
+if __name__ == "__main__":
+    unittest.main()
