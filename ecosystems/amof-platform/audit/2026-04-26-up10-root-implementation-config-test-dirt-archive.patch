+# Mini Ultra Plan 2 / Phase R1 — Runpod provider contract for clouddev.
+#
+# Reuses the LocalOpenAICompatibleClient shape with provider_id="runpod"
+# (validated by _ALLOWED_PROVIDER_IDS in local_openai_compatible.py). This
+# keeps OpenAI-compatible Serverless endpoints behind one client while
+# attribution stays truthful per provider:
+#   * llm_call events carry provider="runpod", model="runpod/<host>/<model>"
+#   * SSE rebroadcast carries provider/failure_class/status_code on errors
+#   * no silent fallback — fallback="none" so a Runpod miss surfaces
+#     instead of leaking back to Anthropic/OpenRouter inside a clouddev
+#     run that was explicitly opted in to Runpod.
+#
+# enabled: false at REST so Helm-deployed clouddev pods boot in a known-safe
+# state. The clouddev_runpod_runner runtime profile is the explicit opt-in
+# switch the runner factory checks at spawn time (mirror of L2 mechanism).
+#
+# Helm clouddev wires RUNPOD_API_KEY + RUNPOD_OPENAI_BASE_URL from the
+# runpod-auth secret into the control-plane pod ONLY for the cloud-dev
+# values file. Proddev is intentionally NOT wired in this phase.
+runpod:
+  enabled: false
+  base_url: "${RUNPOD_OPENAI_BASE_URL}"
+  api_key_env: "RUNPOD_API_KEY"
+  model: "qwen2.5-coder-32b-instruct"
+  timeout: 180
+  fallback: none
+  runner_overrides:
+    enabled_for_profile: ["clouddev_runpod_runner"]
+    allowed_runners: ["code"]
 dry_run: false
