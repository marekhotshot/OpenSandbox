+"""Mini Ultra Plan 2 / Phase L2 — runner-scoped local override tests.
+
+These tests pin down the opt-in semantics of
+:func:`amof.api.services.agent_runner._resolve_runner_local_clients` and
+the per-runner local-client swap inside
+:meth:`amof.orchestrator.runners.RunnerFactory.run_runner`.
+
+The L2 contract has one rule that must never silently drift:
+
+    The default cloud cascade is preserved exactly UNLESS all three
+    conditions are met:
+
+      1. ``local_inference.enabled`` is truthy.
+      2. ``runtime_profile`` is one of ``runner_overrides.enabled_for_profile``.
+      3. The runner being spawned is in ``runner_overrides.allowed_runners``.
+
+If any condition is missing, no override happens. These tests fail loud
+the moment that contract regresses.
+"""
+
+from __future__ import annotations
+
+import sys
+import types
+import unittest
+from pathlib import Path
+from typing import Any, Dict, List, Optional
+
+
+_REPO_ROOT = Path(__file__).resolve().parents[1]
+_SCRIPTS = _REPO_ROOT / "scripts"
+if str(_SCRIPTS) not in sys.path:
+    sys.path.insert(0, str(_SCRIPTS))
+
+
+class _FakeUsage:
+    def __init__(self) -> None:
+        self.model = "qwen2.5-coder:7b-instruct"
+        self.prompt_tokens = 10
+        self.completion_tokens = 5
+        self.estimated_cost = 0.0
+        self.latency_ms = 1
+
+
+class _FakeLLMResponse:
+    def __init__(self) -> None:
+        self.usage = _FakeUsage()
+        self.text = "ok"
+        self.tool_calls = []
+        self.stop_reason = "completed"
+
+
+class _RecordingLLMClient:
+    """Minimal LLMClient stand-in that records ``chat`` invocations.
+
+    Intentionally not a subclass of ``LLMClient`` — the production code
+    only relies on duck-typed ``chat`` / ``chat_structured`` /
+    ``model_name`` / ``provider`` attribute, so the test surface stays
+    truthful about the contract instead of leaking implementation.
+    """
+
+    def __init__(self, *, provider: str, model: str) -> None:
+        self.provider = provider
+        self._model = model
+        self.calls: List[Dict[str, Any]] = []
+
+    def chat(
+        self,
+        system: str,
+        messages: List[Dict[str, Any]],
+        tools: Optional[List[Dict[str, Any]]] = None,
+        max_tokens: int = 8192,
+        temperature: float = 0.0,
+    ) -> _FakeLLMResponse:
+        self.calls.append({"system": system, "messages": messages, "tools": tools})
+        return _FakeLLMResponse()
+
+    def chat_structured(self, *args, **kwargs):
+        raise NotImplementedError
+
+    def model_name(self) -> str:
+        return self._model
+
+    def context_window(self) -> int:
+        return 32000
+
+    def supports_prefill(self) -> bool:
+        return False
+
+    def is_thinking_model(self) -> bool:
+        return False
+
+
+class TestResolveRunnerLocalClients(unittest.TestCase):
+    """``_resolve_runner_local_clients`` must NEVER opt-in by accident."""
+
+    def setUp(self) -> None:
+        from amof.api.services import agent_runner
+        self.resolve = agent_runner._resolve_runner_local_clients
+
+    def _cfg(self, **overrides) -> Dict[str, Any]:
+        base = {
+            "local_inference": {
+                "enabled": True,
+                "base_url": "http://qwen.local:11434/v1",
+                "api_key": "local",
+                "timeout": 30,
+                "runner_overrides": {
+                    "enabled_for_profile": ["local_qwen"],
+                    "allowed_runners": ["code"],
+                    "model": "qwen2.5-coder:7b-instruct",
+                },
+            },
+        }
+        base["local_inference"].update(overrides)
+        return base
+
+    def test_no_runtime_profile_returns_empty(self) -> None:
+        self.assertEqual(self.resolve(self._cfg(), None), {})
+        self.assertEqual(self.resolve(self._cfg(), ""), {})
+
+    def test_wrong_runtime_profile_returns_empty(self) -> None:
+        self.assertEqual(self.resolve(self._cfg(), "default"), {})
+        self.assertEqual(self.resolve(self._cfg(), "clouddev_runpod_runner"), {})
+
+    def test_local_inference_disabled_returns_empty(self) -> None:
+        cfg = self._cfg(enabled=False)
+        self.assertEqual(self.resolve(cfg, "local_qwen"), {})
+
+    def test_runner_overrides_block_absent_returns_empty(self) -> None:
+        cfg = {"local_inference": {"enabled": True, "base_url": "x", "api_key": "y"}}
+        self.assertEqual(self.resolve(cfg, "local_qwen"), {})
+
+    def test_missing_model_returns_empty(self) -> None:
+        cfg = self._cfg()
+        cfg["local_inference"]["runner_overrides"]["model"] = ""
+        self.assertEqual(self.resolve(cfg, "local_qwen"), {})
+
+    def test_missing_base_url_returns_empty(self) -> None:
+        cfg = self._cfg()
+        cfg["local_inference"]["base_url"] = ""
+        self.assertEqual(self.resolve(cfg, "local_qwen"), {})
+
+    def test_only_allowed_runners_get_overridden(self) -> None:
+        cfg = self._cfg()
+        cfg["local_inference"]["runner_overrides"]["allowed_runners"] = ["code", "debug"]
+        result = self.resolve(cfg, "local_qwen")
+        self.assertEqual(set(result.keys()), {"code", "debug"})
+        for client in result.values():
+            self.assertEqual(client.provider, "local")
+            self.assertTrue(client.model_name().startswith("local/"))
+
+    def test_unknown_profile_does_not_match_explicit_list(self) -> None:
+        cfg = self._cfg()
+        cfg["local_inference"]["runner_overrides"]["enabled_for_profile"] = []
+        self.assertEqual(self.resolve(cfg, "local_qwen"), {})
+
+
+class TestRunnerFactoryLocalOverride(unittest.TestCase):
+    """``RunnerFactory.run_runner`` must wire the override + per-runner authority.
+
+    We don't spin up a real Agent loop here (that exists elsewhere) — we
+    monkey-patch ``Agent`` for the duration of the test so we can inspect
+    exactly what kwargs ``RunnerFactory`` constructs the runner Agent
+    with. That is the seam Phase L2 cares about; the rest of the Agent
+    behaviour is covered by the existing agent test suite.
+    """
+
+    def setUp(self) -> None:
+        from amof.orchestrator import runners as runners_mod
+        from amof.orchestrator.tools.base import ToolRegistry, Guardrails
+        self.runners_mod = runners_mod
+
+        self.cloud_client = _RecordingLLMClient(
+            provider="anthropic", model="claude-sonnet-test"
+        )
+        self.local_client = _RecordingLLMClient(
+            provider="local", model="local/qwen.local:11434/qwen2.5-coder:7b-instruct"
+        )
+
+        runner_cfg = runners_mod.RunnerConfig(
+            name="code",
+            prompt_path="prompts/runners/code.md",
+            tool_names=[],
+            description="test code runner",
+            default_tier="standard",
+            max_iterations=1,
+        )
+        debug_cfg = runners_mod.RunnerConfig(
+            name="debug",
+            prompt_path="prompts/runners/debug.md",
+            tool_names=[],
+            description="test debug runner",
+            default_tier="standard",
+            max_iterations=1,
+        )
+        self.factory = runners_mod.RunnerFactory(
+            runners={"code": runner_cfg, "debug": debug_cfg},
+            model_clients={"standard": self.cloud_client, "fast": self.cloud_client},
+            parent_tools=ToolRegistry(guardrails=Guardrails()),
+            workspace_root=Path.cwd(),
+            runner_local_clients={"code": self.local_client},
+        )
+
+        self._orig_agent = runners_mod.Agent
+        self.captured_init: Dict[str, Any] = {}
+
+        class _StubAgent:
+            stop_reason = "completed"
+
+            def __init__(stub_self, **kwargs):
+                self.captured_init.clear()
+                self.captured_init.update(kwargs)
+                stub_self.kwargs = kwargs
+
+            def run(stub_self, _msg):
+                return "ok"
+
+        runners_mod.Agent = _StubAgent
+
+    def tearDown(self) -> None:
+        self.runners_mod.Agent = self._orig_agent
+
+    def test_overridden_runner_receives_local_client(self) -> None:
+        result = self.factory.run_runner("code", task="trivial")
+        self.assertTrue(result.success)
+        self.assertIs(self.captured_init["llm"], self.local_client)
+        self.assertEqual(self.captured_init["llm"].provider, "local")
+
+    def test_non_overridden_runner_keeps_cloud_client(self) -> None:
+        self.factory.run_runner("debug", task="trivial")
+        self.assertIs(self.captured_init["llm"], self.cloud_client)
+        self.assertEqual(self.captured_init["llm"].provider, "anthropic")
+
+    def test_no_authority_means_no_runner_authority(self) -> None:
+        self.factory.run_runner("code", task="trivial")
+        self.assertIsNone(self.captured_init["inference_authority"])
+
+    def test_authority_yields_runner_scoped_sibling(self) -> None:
+        captured_sources: List[str] = []
+
+        class _FakeAuthority:
+            default_source = "master"
+
+            def with_source(_self, source: str):
+                captured_sources.append(source)
+                sibling = types.SimpleNamespace(default_source=source)
+                return sibling
+
+        self.factory._inference_authority = _FakeAuthority()
+        self.factory.run_runner("code", task="trivial")
+        self.assertEqual(captured_sources, ["runner:code"])
+        self.assertEqual(
+            self.captured_init["inference_authority"].default_source, "runner:code"
+        )
+
+
+class TestResolveRunnerRunpodClients(unittest.TestCase):
+    """Mini Ultra Plan 2 / Phase R1: Runpod opt-in must be just as strict.
+
+    Mirrors the L2 contract for ``runpod`` block, with the additional
+    rules that ``enabled: false`` and a missing ``RUNPOD_API_KEY`` env
+    var are both no-op gates. The default canonical config ships with
+    ``enabled: false``, so a baseline ``runpod`` block must NEVER yield
+    runner overrides without an explicit operator opt-in. These tests
+    pin that down.
+    """
+
+    def setUp(self) -> None:
+        from amof.api.services import agent_runner
+        self.resolve = agent_runner._resolve_runner_runpod_clients
+
+    def _cfg(self, **overrides) -> Dict[str, Any]:
+        base = {
+            "runpod": {
+                "enabled": True,
+                "base_url": "${RUNPOD_OPENAI_BASE_URL}",
+                "api_key_env": "RUNPOD_API_KEY",
