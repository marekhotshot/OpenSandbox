-/**
- * AMOF API — calls AMOF control plane (ecosystems, arena, chat).
- * Set NEXT_PUBLIC_AMOF_API to use this; otherwise mock is used.
- */
-
-import type {
-  AssistantAPI,
-  AssistantBootstrapResponse,
-  AssistantConversationState,
-  SendMessageRequest,
-  SendMessageResponse,
-} from "./types";
-import type { ChatMessage } from "../types";
-import { getRuntimeConfig } from "@/lib/runtime-config";
-
-const DEFAULT_ECOSYSTEM = process.env.NEXT_PUBLIC_AMOF_ECOSYSTEM ?? "demo-microsaas";
-const DEFAULT_AGENT_ID = process.env.NEXT_PUBLIC_AMOF_AGENT_ID ?? "director";
-const DEFAULT_ARENA_MODE = process.env.NEXT_PUBLIC_AMOF_ARENA_MODE ?? "main";
-
-type ArenaThreadRow = {
-  thread_id?: string;
-  root_session_id?: string;
-  latest_session_id?: string;
-  arena_mode?: string;
-};
-
-type ArenaMessageRow = {
-  id?: number;
-  role?: string;
-  content?: string;
-};
-
-function getApiBase(): string {
-  const base = getRuntimeConfig().amofApiBase.trim();
-  if (!base) return "";
-  return base.replace(/\/$/, "");
-}
-
-function mapArenaRole(role: string | undefined): ChatMessage["role"] | null {
-  if (role === "user") return "user";
-  if (role === "agent" || role === "assistant" || role === "report") return "assistant";
-  return null;
-}
-
-function mapArenaMessages(rows: ArenaMessageRow[]): ChatMessage[] {
-  return rows
-    .map((row, index) => {
-      const role = mapArenaRole(row.role);
-      if (!role || typeof row.content !== "string") return null;
-      return {
-        id: typeof row.id === "number" ? `arena-${row.id}` : `arena-${index}-${Date.now()}`,
-        role,
-        content: row.content,
-        timestamp: Date.now(),
-      } satisfies ChatMessage;
-    })
-    .filter((row): row is ChatMessage => row !== null);
-}
-
-async function fetchJson<T>(input: string, init?: RequestInit): Promise<T> {
-  const response = await fetch(input, { credentials: "include", ...(init ?? {}) });
-  if (!response.ok) {
-    throw new Error(`AMOF API ${response.status}: ${response.statusText}`);
-  }
-  return (await response.json()) as T;
-}
-
-async function loadPrimaryThread(
-  base: string,
-  ecosystem: string,
-  agentId: string,
-): Promise<ArenaThreadRow> {
-  const params = new URLSearchParams({ agent_id: agentId });
-  const payload = await fetchJson<{ threads?: ArenaThreadRow[] }>(
-    `${base}/ecosystems/${encodeURIComponent(ecosystem)}/arena/threads?${params.toString()}`,
-  );
-  const thread = Array.isArray(payload.threads) ? payload.threads[0] : undefined;
-  if (!thread?.thread_id) {
-    throw new Error("AMOF did not return an arena thread");
-  }
-  return thread;
-}
-
-async function loadThreadMessages(
-  base: string,
-  ecosystem: string,
-  agentId: string,
-  threadId: string,
-  arenaMode: string,
-): Promise<ChatMessage[]> {
-  const params = new URLSearchParams({
-    thread_id: threadId,
-    mode: arenaMode,
-    limit: "1000",
-  });
-  const payload = await fetchJson<{ messages?: ArenaMessageRow[] }>(
-    `${base}/ecosystems/${encodeURIComponent(ecosystem)}/arena/chats/${encodeURIComponent(agentId)}?${params.toString()}`,
-  );
-  return mapArenaMessages(Array.isArray(payload.messages) ? payload.messages : []);
-}
-
-function waitForRunToFinish(base: string, runId: string): Promise<void> {
-  return new Promise((resolve, reject) => {
-    const stream = new EventSource(`${base}/runs/${encodeURIComponent(runId)}/stream`);
-    let settled = false;
-
-    const finish = (callback: () => void) => {
-      if (settled) return;
-      settled = true;
-      stream.close();
-      callback();
-    };
-
-    stream.onmessage = (event) => {
-      const text = typeof event.data === "string" ? event.data : String(event.data);
-      if (text === "[DONE]") {
-        finish(resolve);
-      }
-    };
-
-    stream.onerror = () => {
-      finish(() => reject(new Error("AMOF stream closed before completion")));
-    };
-  });
-}
-
-export class AmofAssistantAPI implements AssistantAPI {
-  async initializeConversation(): Promise<AssistantBootstrapResponse> {
-    const base = getApiBase();
-    if (!base) {
-      throw new Error("NEXT_PUBLIC_AMOF_API is not set");
-    }
-    const thread = await loadPrimaryThread(base, DEFAULT_ECOSYSTEM, DEFAULT_AGENT_ID);
-    const conversation: AssistantConversationState = {
-      ecosystem: DEFAULT_ECOSYSTEM,
-      agentId: DEFAULT_AGENT_ID,
-      threadId: thread.thread_id,
-      sessionId: thread.latest_session_id ?? thread.root_session_id,
-      arenaMode: thread.arena_mode ?? DEFAULT_ARENA_MODE,
-    };
-    const threadId = thread.thread_id;
-    if (!threadId) {
-      throw new Error("AMOF did not return a thread_id");
-    }
-    const messages = await loadThreadMessages(
-      base,
-      DEFAULT_ECOSYSTEM,
-      DEFAULT_AGENT_ID,
-      threadId,
-      conversation.arenaMode ?? DEFAULT_ARENA_MODE,
-    );
-    return { messages, conversation };
-  }
-
-  async sendMessage(
-    request: SendMessageRequest,
-    conversation?: AssistantConversationState,
-  ): Promise<SendMessageResponse> {
-    const base = getApiBase();
-    if (!base) {
-      throw new Error("NEXT_PUBLIC_AMOF_API is not set");
-    }
-
-    const ecosystem = conversation?.ecosystem ?? DEFAULT_ECOSYSTEM;
-    const agentId = conversation?.agentId ?? DEFAULT_AGENT_ID;
-    const arenaMode = conversation?.arenaMode ?? DEFAULT_ARENA_MODE;
-
-    const thread =
-      conversation?.threadId
-        ? {
-            thread_id: conversation.threadId,
-            latest_session_id: conversation.sessionId,
-            root_session_id: conversation.sessionId,
-            arena_mode: arenaMode,
-          }
-        : await loadPrimaryThread(base, ecosystem, agentId);
-
-    const threadId = thread.thread_id;
-    if (!threadId) {
-      throw new Error("AMOF thread is missing thread_id");
-    }
-
-    await fetchJson(
-      `${base}/ecosystems/${encodeURIComponent(ecosystem)}/arena/chats/${encodeURIComponent(agentId)}/messages`,
-      {
-        method: "POST",
-        headers: { "Content-Type": "application/json" },
-        body: JSON.stringify({
-          role: "user",
-          content: request.userText,
-          mode: arenaMode,
-          thread_id: threadId,
-        }),
-      },
-    );
-
-    const action = await fetchJson<{
-      run_id?: string;
-      session_id?: string;
-      thread_id?: string;
-    }>(`${base}/ecosystems/${encodeURIComponent(ecosystem)}/actions/agent`, {
-      method: "POST",
-      headers: { "Content-Type": "application/json" },
-      body: JSON.stringify({
-        prompt: request.userText,
-        mode: "execute",
-        session_id: conversation?.sessionId ?? thread.latest_session_id ?? thread.root_session_id,
-        agent_id: agentId,
-        thread_id: threadId,
-        arena_mode: arenaMode,
-        trigger_kind: "user",
-      }),
-    });
-
-    if (!action.run_id) {
-      throw new Error("AMOF did not return a run_id");
-    }
-
-    try {
-      await waitForRunToFinish(base, action.run_id);
-    } catch {
-      // If SSE drops, reload persisted history anyway; the backend persists final chat rows.
-    }
-
-    const nextConversation: AssistantConversationState = {
-      ecosystem,
-      agentId,
-      threadId: action.thread_id ?? threadId,
-      sessionId:
-        action.session_id ?? conversation?.sessionId ?? thread.latest_session_id ?? thread.root_session_id,
-      arenaMode,
-    };
-
-    const messages = await loadThreadMessages(
-      base,
-      ecosystem,
-      agentId,
-      nextConversation.threadId ?? threadId,
-      arenaMode,
-    );
-
-    return { messages, conversation: nextConversation, replaceAll: true };
-  }
-}
-
-export const amofAPI = new AmofAssistantAPI();
